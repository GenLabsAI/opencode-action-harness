FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/agent/home
ENV PATH=/agent/home/.local/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        nodejs \
        npm \
        python3 \
        python3-pip \
        python3-venv \
        zstd \
    && npm install -g opencode-ai \
    && mkdir -p /agent/workspace /agent/home \
    && rm -rf /var/lib/apt/lists/*

COPY runner.py /agent/harness/runner.py
COPY git-askpass.sh /agent/harness/git-askpass.sh
RUN chmod +x /agent/harness/git-askpass.sh \
    && git config --global user.name "Deca Agent" \
    && git config --global user.email "deca-agent@genlabs.dev"
WORKDIR /agent/workspace
